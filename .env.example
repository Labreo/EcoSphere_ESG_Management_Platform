# EcoSphere ESG Management Platform - Environment Configuration
# Copy this file to .env and fill in your values

# === Authentication ===
SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_REFRESH_SECRET=your-jwt-refresh-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# === Database ===
DATABASE_URL=sqlite:///./ecosphere_esg.db
# For PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/ecosphere

# === Google Gemini AI (for EcoBot Chatbot) ===
GOOGLE_GEMINI_API_KEY=your_gemini_api_key_here

# === Brevo SMTP (Transactional Email) ===
BREVO_API_KEY=your_brevo_api_key_here
SMTP_FROM_EMAIL=noreply@ecosphere.com
SMTP_FROM_NAME=EcoSphere Platform

# === File Upload (ImageKit) ===
IMAGEKIT_PUBLIC_KEY=your_imagekit_public_key
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_id

# === Redis (Caching & Rate Limiting) ===
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# === Google OAuth 2.0 ===
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# === Application ===
CORS_ORIGINS=*
DEBUG=true
PORT=8000
CLIENT_URL=https://melodious-kitsune-accd4e.netlify.app
